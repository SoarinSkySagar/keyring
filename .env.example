# Keyring — environment variables
# Copy this file to .env and fill in every value.
# Both client/ and tee-worker/ symlink to this file — only one .env to manage.

# ── Privy (auth) ─────────────────────────────────────────────────
# https://dashboard.privy.io → Settings → App ID / App Secret
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── Database (PostgreSQL / Neon) ─────────────────────────────────
# https://console.neon.tech → project → connection string (pooled)
DATABASE_URL=

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Contracts (Story Protocol Aeneid testnet) ────────────────────
# Deployed once by the team via: cd contracts && forge script script/Deploy.s.sol
NEXT_PUBLIC_KEYRING_FACTORY_ADDRESS=

# ── Pimlico (gas sponsorship for agent CDR reads) ────────────────
# https://dashboard.pimlico.io → API Keys
PIMLICO_API_KEY=
PIMLICO_AENEID_TESTNET_URL=https://api.pimlico.io/v2/1315/rpc?apikey=YOUR_KEY

# ── TEE worker ───────────────────────────────────────────────────
# Local dev: http://localhost:3001/execute
# Production: https://<your-phala-host>/execute
TEE_WORKER_URL=http://localhost:3001/execute

# Gemini API key — the TEE worker's policy judge
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Port the tee-worker listens on
TEE_PORT=3001

# ── dstack simulator (local dev only) ────────────────────────────
# Leave BOTH unset in production — Phala mounts the real /var/run/dstack.sock
# To install the simulator: https://docs.phala.network/developers/getting-started
DSTACK_SIMULATOR_ENDPOINT=
TAPPD_SIMULATOR_ENDPOINT=

# ── Resend (optional — email OTP auth flow) ──────────────────────
# https://resend.com/api-keys
# RESEND_API_KEY=
