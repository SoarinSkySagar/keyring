# Keyring TEE worker — environment

# dstack endpoints. Leave BOTH unset in production (Phala mounts the real
# /var/run/dstack.sock and the SDK defaults to it). Set them only for local
# development against the dstack simulator.
DSTACK_SIMULATOR_ENDPOINT=
TAPPD_SIMULATOR_ENDPOINT=

# Google Gemini — the policy judge. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# HTTP port the worker listens on
PORT=3001
